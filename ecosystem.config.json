{
  "apps": [
    {
      "name": "hermes-api",
      "script": "server/api.py",
      "interpreter": "/app/.venv/bin/python",
      "cwd": "/app",
      "env": {
        "HERMES_NO_COLOR": "1",
        "API_SERVER_KEY": "your-api-server-key-here"
      },
      "autorestart": true,
      "max_memory_restart": "200M"
    },
    {
      "name": "hermes-dashboard",
      "script": "node_modules/.bin/next",
      "args": "start -p 3000",
      "cwd": "/app",
      "autorestart": true,
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "production",
        "NEXT_PUBLIC_API_URL": ""
      }
    }
  ]
}
